OPENAI_API_KEY=sk-...

# gpt-4o-mini matches the FE pipeline. Switch to gpt-4o if accuracy beats cost.
EXTRACTION_MODEL=gpt-4o-mini
COMPLIANCE_MODEL=gpt-4o-mini

# Epic 2 (RAG) — OpenAI embeddings for STR chunks. 1536 dims, ~$0.02/1M tokens.
EMBEDDING_MODEL=text-embedding-3-small

# Use RAG (vector retrieval from data/str_texts) for compliance checks.
# Requires `uv sync --extra rag` AND a populated vector_store/ (run scripts/ingest_str.py).
USE_RAG=false
RAG_TOP_K=5

# Stage 3 — route each item to a specialized agent (structural / fire_safety /
# sanitary / energy / documents). Falls back to BasicChecker / RAGChecker for
# items no agent claims (most laws + non-HN standards). Stack on top of USE_RAG
# if you want RAG-augmented agents (Stage 3 + Stage 2). Precedence:
# USE_AGENTS > USE_RAG > BasicChecker — when USE_AGENTS=true the orchestrator's
# own fallback respects USE_RAG for unmapped items.
USE_AGENTS=false

# Legacy CLI/Streamlit batched flow only — not used by the FastAPI compliance_flow.
MAX_TOKENS_PER_CHUNK=10000
STR_BATCH_SIZE=6

# Proactive TPM pacing for the BasicChecker. Default matches OpenAI Tier 1
# gpt-4o-mini (200K TPM). The limiter throttles at 70% of this value to leave
# headroom; bump it up if you've been moved to Tier 2+.
OPENAI_TPM_LIMIT=200000

# FastAPI server
# Comma-separated list of origins allowed by CORS (Next.js dev + prod URLs).
ALLOWED_ORIGINS=http://localhost:3000

# Shared bearer token between Next.js and Python service. Leave empty to disable auth (dev only).
INTERNAL_API_TOKEN=

# Supabase — names match nextjs-fe so a single .env can be shared between projects.
# NEXT_PUBLIC_SUPABASE_URL is the FE-style name; plain SUPABASE_URL also works as override.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
